#!/usr/bin/env bash
# Git credential helper for Azure DevOps using Entra (AAD) access tokens.
#
# Git invokes credential helpers with one argument: get | store | erase.
# For `get`, it sends key=value lines on stdin (protocol, host, path, ...)
# and expects key=value lines on stdout, including username= and password=.
#
# Caching is handled by configuring `credential.helper store` alongside
# this helper: git tries the stored token first, calls `erase` on 401,
# then calls `get` again to fetch a fresh one. This script just fetches
# a token on demand; `store`/`erase` are no-ops.

set -euo pipefail

action="${1:-}"

# Azure DevOps resource ID (constant, do not change).
ADO_RESOURCE_ID="499b84ac-1321-427f-aa17-267ca6975798"

read_stdin_request() {
    # Drain stdin so git doesn't get SIGPIPE; we don't actually need the values.
    while IFS= read -r line; do
        [[ -z "$line" ]] && break
    done || true
}

fetch_token() {
    az account get-access-token \
        --resource "$ADO_RESOURCE_ID" \
        --query accessToken \
        -o tsv
}

case "$action" in
    get)
        read_stdin_request
        token=$(fetch_token)
        printf 'username=%s\n' "$USER"
        printf 'password=%s\n' "$token"
        ;;
    store|erase)
        read_stdin_request
        ;;
    *)
        echo "usage: $0 {get|store|erase}" >&2
        exit 1
        ;;
esac
