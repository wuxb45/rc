#!/usr/bin/env bash
# Git credential helper for Azure DevOps using Entra (AAD) access tokens.
#
# Git invokes credential helpers with one argument: get | store | erase.
# For `get`, it sends key=value lines on stdin (protocol, host, path, ...)
# and expects key=value lines on stdout, including username= and password=.
#
# We only implement `get`; `store` and `erase` are no-ops because the token
# is short-lived and re-fetched on demand.

set -euo pipefail

action="${1:-}"

# Azure DevOps resource ID (constant, do not change).
ADO_RESOURCE_ID="499b84ac-1321-427f-aa17-267ca6975798"

# Optional: cache the token on disk to avoid calling `az` on every git op.
# `az` itself caches tokens, but invoking it still costs ~hundreds of ms.
CACHE_DIR="${XDG_CACHE_HOME:-$HOME/.cache}/git-credential-azuredevops"
CACHE_FILE="$CACHE_DIR/token"
# Refresh a bit before the 1h expiry to avoid races.
SAFETY_MARGIN_SECONDS=300

read_stdin_request() {
    # Drain stdin so git doesn't get SIGPIPE; we don't actually need the values.
    while IFS= read -r line; do
        [[ -z "$line" ]] && break
    done || true
}

token_is_fresh() {
    [[ -f "$CACHE_FILE" ]] || return 1
    local mtime now age
    mtime=$(stat -c %Y "$CACHE_FILE")
    now=$(date +%s)
    age=$(( now - mtime ))
    (( age < 3600 - SAFETY_MARGIN_SECONDS ))
}

fetch_token() {
    az account get-access-token \
        --resource "$ADO_RESOURCE_ID" \
        --query accessToken \
        -o tsv
}

get_token() {
    if token_is_fresh; then
        cat "$CACHE_FILE"
        return
    fi
    mkdir -p "$CACHE_DIR"
    chmod 700 "$CACHE_DIR"
    local token
    token=$(fetch_token)
    # Write atomically with restrictive perms.
    umask 077
    printf '%s' "$token" > "$CACHE_FILE.tmp"
    mv "$CACHE_FILE.tmp" "$CACHE_FILE"
    printf '%s' "$token"
}

case "$action" in
    get)
        read_stdin_request
        token=$(get_token)
        # Username can be anything non-empty for ADO when using a bearer/PAT
        # over Basic auth. Use a recognizable label.
        printf 'username=%s\n' "$USER"
        printf 'password=%s\n' "$token"
        ;;
    store|erase)
        # Drain stdin to be polite. On `erase` (git saw a 401), drop the
        # cached token so the immediate retry forces a fresh `az` call.
        read_stdin_request
        [[ "$action" == "erase" ]] && rm -f "$CACHE_FILE"
        ;;
    *)
        echo "usage: $0 {get|store|erase}" >&2
        exit 1
        ;;
esac
