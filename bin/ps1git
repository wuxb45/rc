#!/usr/bin/env bash

# Bail out fast when not inside a work tree (cheap, no worktree walk).
[[ "$(git rev-parse --is-inside-work-tree 2>/dev/null)" == true ]] || exit 0

# current head: "<shortsha> <branch>" on a branch, "<describe>" when detached,
# or just the branch name on an unborn branch (no commits yet).
curhead=
branch="$(git symbolic-ref --quiet --short HEAD 2>/dev/null)"
shortv="$(git rev-parse --short HEAD 2>/dev/null)"
if [[ -n ${branch} ]]; then
  if [[ -z ${shortv} ]]; then
    curhead="${branch}"
  else
    curhead="${shortv} ${branch}"
  fi
else
  # detached HEAD: prefer an exact tag, else fall back to the short sha.
  curhead="$(git describe --tags --exact-match HEAD 2>/dev/null)"
  [[ -z ${curhead} ]] && curhead="${shortv}"
fi

# local status from porcelain (locale-stable):
#   col 1 (staged)   in [MADRC]  -> "Changes to be committed"  -> "!"
#   col 2 (worktree) in [MD]     -> "Changes not staged"       -> "?"
lst=
porc="$(git status --porcelain 2>/dev/null)"
[[ ${porc} =~ (^|$'\n').[MD] ]] && lst="${lst}?"
[[ ${porc} =~ (^|$'\n')[MADRC] ]] && lst="${lst}!"

# upstream divergence via rev-list: "<behind> <ahead>".
rst=
lr="$(git rev-list --left-right --count '@{u}...HEAD' 2>/dev/null)"
if [[ ${lr} =~ ^([0-9]+)[${IFS}]+([0-9]+)$ ]]; then
  behind=${BASH_REMATCH[1]}
  ahead=${BASH_REMATCH[2]}
  if (( behind > 0 && ahead > 0 )); then
    rst=" L<>R"
  elif (( behind > 0 )); then
    rst=" L<<R"
  elif (( ahead > 0 )); then
    rst=" L>>R"
  fi
fi

[[ -n ${curhead} ]] && echo -n "(${curhead}${lst}${rst})"
